# .env.example — OmniNet Quantum-Core Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=omninet
POSTGRES_USER=omninet
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ── FastAPI Security ──────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_64_CHARS_MINIMUM
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
# Options: trial | community | bank
DEFAULT_LICENSE_TIER=trial

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# ── Network Discovery ─────────────────────────────────────────────────────────
# Default SSH credentials used for device discovery (override per-device in UI)
DISCOVERY_SSH_USERNAME=admin
DISCOVERY_SSH_PASSWORD=CHANGE_THIS_SSH_PASSWORD
DISCOVERY_SSH_PORT=22
DISCOVERY_TIMEOUT_SECONDS=30

# ── AI Predictor ──────────────────────────────────────────────────────────────
AI_FAILURE_THRESHOLD=0.75
AI_MODEL_PATH=/app/models/
AI_RETRAIN_INTERVAL_HOURS=24

# ── Quantum Engine ────────────────────────────────────────────────────────────
QUANTUM_KEY_ROTATION_HOURS=12
QUANTUM_AAA_ENABLED=true

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,https://yourdomain.com

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Default admin account created at first startup (change BEFORE first deployment)
# Generate a strong password: python3 -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#$%^&*') for _ in range(24)))"
ADMIN_DEFAULT_EMAIL=admin@omninet.local
ADMIN_DEFAULT_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
# Directory where Nginx looks for server.crt and server.key.
# In development: auto-generated self-signed certs are created at container start.
# In production:  mount real Let's Encrypt certificates here:
#   volumes:
#     - /etc/letsencrypt/live/yourdomain.com/fullchain.pem:/etc/nginx/certs/server.crt:ro
#     - /etc/letsencrypt/live/yourdomain.com/privkey.pem:/etc/nginx/certs/server.key:ro
NGINX_CERT_DIR=/etc/nginx/certs
# Secret key used to sign and verify HMAC license keys (min 32 chars, random)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LICENSE_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_LICENSE_SECRET_KEY

# Comma-separated list of allowed CORS origins (no wildcards in production)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Set to "development" to enable legacy hardcoded test license keys
# ENVIRONMENT=production  (already set above)

# Comma-separated legacy test keys enabled only when ENVIRONMENT=development
LEGACY_LICENSE_KEYS=TRIAL-OMNINET-2026,COMMUNITY-GENIO-ELITE,BANK-QUANTUM-SECURE

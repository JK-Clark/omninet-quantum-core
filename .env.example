# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=omninet
POSTGRES_PASSWORD=omninet_secret_change_me
POSTGRES_DB=omninet

# ─── Backend ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://omninet:omninet_secret_change_me@db:5432/omninet
SECRET_KEY=change-me-in-production-minimum-32-characters!!
# JWT / Quantum-AAA signing algorithm.  Consumed by database.py Settings and
# used by main.py for JWT token creation and verification.
# Supported values: HS256, HS384, HS512.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REDIS_URL=redis://redis:6379/0
MODEL_DIR=/app/models

# ─── Nginx ───────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=omninet_grafana_change_me

# ─── Network Discovery ────────────────────────────────────────────────────────
# Credentials for topology discovery are supplied per-request via the API.
# The device_type field in POST /api/topology/discover must be one of:
#   Cisco IOS        : cisco_ios
#   Cisco NX-OS      : cisco_nxos
#   Arista EOS       : arista_eos
#   Juniper JunOS    : juniper_junos
#   Fortinet FortiOS : fortinet
#   Palo Alto PAN-OS : paloalto_panos
#   Checkpoint Gaia  : checkpoint_gaia

# ─── Monthly Audit Reports ────────────────────────────────────────────────────
# SMTP configuration for automated monthly PDF report delivery.
# The report fires on the 1st of every month at 07:00 UTC (requires BANK tier).
#
# SMTP_HOST         SMTP relay hostname (e.g. smtp.sendgrid.net)
# SMTP_PORT         SMTP port — 587 for STARTTLS, 465 for TLS (default: 587)
# SMTP_TLS          Use STARTTLS: "true" (default) or "false"
# SMTP_USER         SMTP username / API key
# SMTP_PASSWORD     SMTP password / API key secret
# REPORT_RECIPIENTS Comma-separated list of recipient email addresses
# REPORT_LANGUAGE   Report language: EN (default), FR, HI, or KO
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=omninet@example.com
SMTP_PASSWORD=change-me
REPORT_RECIPIENTS=cto@example.com,soc@example.com
REPORT_LANGUAGE=EN

# ─── Server Health (Redfish / SNMP) ──────────────────────────────────────────
# Credentials for BMC/OOB server health collection via POST /api/health/server.
# bmc_type: idrac (Dell iDRAC), ilo (HP iLO), imm (IBM/Lenovo IMM — uses SNMP)
# SNMP community string for IBM/Lenovo IMM:
SNMP_COMMUNITY=public
